# ─────────────────────────────────────────────────
# Goethe Booking Bot — Environment Configuration
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# python -c "import crypto_utils; print('FERNET_KEY='+crypto_utils.generate_fernet_key())"

# ═════════════════════════════════════════════════
# REQUIRED — Admin Login
# ═════════════════════════════════════════════════
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=change-me-in-production


# ═════════════════════════════════════════════════
# REQUIRED for Railway/Production — Database
# ═════════════════════════════════════════════════
# SQLite (local dev only, data lost on Railway restart):
#   DATABASE_URL=
# PostgreSQL (production — Railway add-on):
#   DATABASE_URL=
DATABASE_URL=

# ═════════════════════════════════════════════════
# REQUIRED for Encryption — Student Password Storage
# ═════════════════════════════════════════════════
# Generate via: python -c "import crypto_utils; print(crypto_utils.generate_fernet_key())"
# If empty, an ephemeral key is generated on each startup
#   → existing encrypted passwords become undecryptable on restart
FERNET_KEY=

# ═════════════════════════════════════════════════
# OPTIONAL — Google Sheets Integration
# ═════════════════════════════════════════════════
# Sheet ID from your Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# ═════════════════════════════════════════════════
# OPTIONAL — Notifications (Telegram + Email)
# ═════════════════════════════════════════════════
# Telegram bot (@BotFather → create bot → get token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=

# ═════════════════════════════════════════════════
# OPTIONAL — Alexa AI Assistant
# ═════════════════════════════════════════════════
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ═════════════════════════════════════════════════
# OPTIONAL — CAPTCHA Solving
# ═════════════════════════════════════════════════
# 2Captcha API key (https://2captcha.com)
CAPTCHA_API_KEY=

# ═════════════════════════════════════════════════
# OPTIONAL — Proxy Rotation
# ═════════════════════════════════════════════════
# Comma-separated list of proxies (protocol://user:pass@host:port)
PROXY_LIST=

# ═════════════════════════════════════════════════
# OPTIONAL — Error Tracking
# ═════════════════════════════════════════════════
SENTRY_DSN=

# ═════════════════════════════════════════════════
# OPTIONAL — Mock Exam URLs (for testing without goethe.de)
# ═════════════════════════════════════════════════
MOCK_A1_URL=
MOCK_A2_URL=
MOCK_B1_URL=

# ═════════════════════════════════════════════════
# OPTIONAL — Bot Behaviour Tuning
# ═════════════════════════════════════════════════
# Polling interval (seconds) and jitter
POLL_INTERVAL=10
POLL_JITTER=5

# Max retries for transient errors
MAX_SMART_RETRIES=2

# Circuit breaker: threshold (failures to trip) & cooldown (seconds)
CB_BLOCK_THRESHOLD=5
CB_BLOCK_COOLDOWN=900
CB_TIMEOUT_THRESHOLD=10
CB_TIMEOUT_COOLDOWN=300
CB_GENERIC_THRESHOLD=10
CB_GENERIC_COOLDOWN=900

# ═════════════════════════════════════════════════
# OPTIONAL — Server Configuration
# ═════════════════════════════════════════════════
PORT=5000
HOST=0.0.0.0

# Enforce HTTPS redirect (set to 1 or true in production with SSL)
ENFORCE_HTTPS=false

# Salt for session token generation (change in production)
AUTH_SALT=goethe-bot-salt-2026

# Support email shown in forgot-password response
SUPPORT_EMAIL=admin@example.com
