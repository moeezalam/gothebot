# Required: Gemini API key for Alexa AI assistant
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: CAPTCHA solving (2Captcha)
CAPTCHA_API_KEY=your_2captcha_key_here

# Optional: Proxy rotation (comma-separated)
PROXY_LIST=proxy1:port,proxy2:port

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional: Email notifications
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# Admin login (change for production)
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=ADMIN_PASSWORD_REDACTED
